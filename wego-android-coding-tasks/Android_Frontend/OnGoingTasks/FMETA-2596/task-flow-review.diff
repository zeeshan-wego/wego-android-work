+    @Test
+    public void updateRecyclerView_disclaimerAndHajjAndPersonalization_bannerOrderIsCorrect() throws Exception {
+        JacksonFlightTrip disclaimer = new JacksonFlightTrip();
+        disclaimer.setType(JacksonFlightTrip.TYPE_DISCLAIMER);
+        setAdapterField("disclaimerItem", disclaimer);
+        setAdapterField("isHajjSeasonActive", true);
+        setAdapterField("showPersonalizationBanner", true);
+
+        adapter.updateRecyclerView();
+
+        List<JacksonFlightTrip> displayed = getDisplayedTrips();
+        assertEquals("First item should be disclaimer", JacksonFlightTrip.TYPE_DISCLAIMER, displayed.get(0).getType());
+        assertEquals("Second item should be hajj warning", JacksonFlightTrip.TYPE_HAJJ_SEASON_WARNING, displayed.get(1).getType());
+        assertEquals("Third item should be personalization banner", JacksonFlightTrip.TYPE_PERSONALIZATION_BANNER, displayed.get(2).getType());
+    }
+
